# Leave DATABASE_URL unset to use a local SQLite file (zero-config, runs anywhere).
# To use PostgreSQL (as specified in the product doc):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/health_intel
DATABASE_URL=

# Comma-separated list of origins allowed to call the API (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000

# Optional — enables Claude-powered plain-language report narration.
# Leave blank to use the deterministic rule-based summary instead.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Secret used to sign login tokens. CHANGE THIS in any real deployment.
JWT_SECRET=dev-only-insecure-secret-change-me
